# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Scripts in scripts/ auto-load .env; for raw `python main.py` either export
# these yourself or `set -a; source .env; set +a` first.

# Required: auth token for the mushigen proxy.
LLM_API_KEY=sk-your-token-here

# Target codebase to analyze (game server / combat / client / engine).
# Defaults to ./target_code (sample code) if unset.
TARGET_CODE_PATH=/path/to/game-code

# Optional overrides (defaults shown in config.py):
# LLM_MODEL=vertex_ai/gemini-3.5-flash
# LLM_API_BASE=https://mushigen.comet.scopelyai.com/v1
# SERVICE_PORT=8900
# AGENT_MAX_ITERATIONS=12
