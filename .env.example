# ============================================================================
# code-agent 环境变量配置模板
#
# 用法：复制为 .env 并填写。.env 已被 .gitignore 排除，切勿提交真实密钥。
# scripts/ 下的脚本会自动加载 .env；裸跑 `python main.py` 时需先手动导出，
# 例如：set -a; source .env; set +a
#
# 标注说明：
#   [必填]  必须设置，否则无法工作
#   [可选]  不设则用括号内默认值
#   后端：custom = litellm 循环（默认）；sdk = Claude Agent SDK
# ============================================================================

# ----------------------------------------------------------------------------
# 基础（两个后端都用）
# ----------------------------------------------------------------------------

# [必填] LLM 代理的认证 token。custom 与 sdk 后端共用同一个 token。
LLM_API_KEY=sk-your-token-here

# [可选] 被分析的目标代码库绝对路径（游戏服务器 / 战斗 / 客户端 / 引擎）。
#        单仓库模式使用；不设则默认 ./target_code（仓库自带的示例代码）。
TARGET_CODE_PATH=/path/to/game-code

# [可选] 多仓库模式。设置后可在 HTTP/CLI/MCP 请求里用 repo 选择。
#        索引/知识库/项目概览会按仓库名隔离到 index/repos/<repo>/。
# CODE_REPOS=gameserver=/path/to/gameserver,ecs=/path/to/ecs
# CODE_REPO_DEFAULT=gameserver

# [可选] 选择 agent 后端：custom（litellm，支持 gemini/GPT/Claude 等任意代理模型）
#        或 sdk（Claude Agent SDK + Claude Code CLI，仅支持 Claude 系模型）。
#        默认 custom。
AGENT_BACKEND=custom

# [可选] 开启的回答/操作模式。默认允许 plain 与 technical；edit 必须显式追加。
# AGENT_ALLOWED_MODES=plain,technical

# ----------------------------------------------------------------------------
# custom 后端（litellm，AGENT_BACKEND=custom 时生效）
# ----------------------------------------------------------------------------

# [可选] 模型 id（默认 vertex_ai/gemini-3.5-flash）。
#        可填代理 GET /v1/models 列出的任意 id，如 us.anthropic.claude-sonnet-4-6。
LLM_MODEL=vertex_ai/gemini-3.5-flash

# [可选] LLM 代理地址，OpenAI 兼容网关，注意是 /v1 路径
#        （默认 http://10.253.17.63:8090/v1）。
LLM_API_BASE=http://10.253.17.63:8090/v1

# [可选] 采样温度，0 = 最稳定（默认 0）。
# LLM_TEMPERATURE=0

# [可选] 单次 LLM 调用超时秒数（默认 120）。
# LLM_TIMEOUT=120

# ----------------------------------------------------------------------------
# sdk 后端（Claude Agent SDK + Claude Code CLI，AGENT_BACKEND=sdk 时生效）
# 经 Bedrock 协议调用，下列变量由 Claude Code CLI 读取。
# ----------------------------------------------------------------------------

# [可选] sdk 后端使用的模型（Bedrock 模型 id）。
#        不设则取 ANTHROPIC_MODEL，再不设则默认 us.anthropic.claude-opus-4-8。
# SDK_MODEL=us.anthropic.claude-opus-4-8

# [可选] Bedrock 代理地址，注意是 /bedrock 路径
#        （默认 http://10.253.17.63:8090/bedrock）。
ANTHROPIC_BEDROCK_BASE_URL=http://10.253.17.63:8090/bedrock

# [可选] 以下 4 项是 Claude Code CLI 走 Bedrock 所需的开关/凭据；
#        agent_sdk.py 已为它们提供默认值，通常无需显式设置。
# CLAUDE_CODE_USE_BEDROCK=1            # 启用 Bedrock 模式
# CLAUDE_CODE_SKIP_BEDROCK_AUTH=1      # 跳过原生 AWS 鉴权（走代理 token）
# AWS_REGION=us-east-1                 # 区域
# ANTHROPIC_AUTH_TOKEN=sk-your-token-here  # 代理 token，默认复用 LLM_API_KEY

# ----------------------------------------------------------------------------
# REST 服务（main.py）
# ----------------------------------------------------------------------------

# [可选] HTTP 监听地址（默认 0.0.0.0）。
# SERVICE_HOST=0.0.0.0

# [可选] HTTP 端口（默认 8900）。
# SERVICE_PORT=8900

# [可选] 并发治理（/ask + /diagnose）：最大并发数（默认 4）。
# MAX_CONCURRENCY=4
# [可选] 超出并发时最多排队数，再多返回 503（默认 8）。
# MAX_QUEUE=8
# [可选] 单请求超时秒数，超时返回 504（默认 180）。
# REQUEST_TIMEOUT=180
# [可选] /ask 答案缓存上限（LRU 淘汰），0=禁用缓存（默认 512）。
# CACHE_MAX_ENTRIES=512

# ----------------------------------------------------------------------------
# MCP 服务（mcp_server.py，供其它 MCP 客户端调用）
# ----------------------------------------------------------------------------

# [可选] MCP 监听地址（默认 0.0.0.0）。
# MCP_HOST=0.0.0.0

# [可选] MCP 端口，与 REST 的 8900 分开（默认 8901）。
# MCP_PORT=8901

# [可选] MCP 端点路径（默认 /mcp）。客户端连 http://<host>:<port>/mcp。
# MCP_PATH=/mcp

# ----------------------------------------------------------------------------
# Agent 循环与工具输出限制（两个后端都用）
# ----------------------------------------------------------------------------

# [可选] agent 最多调用工具的轮数（默认 12）。
# AGENT_MAX_ITERATIONS=12

# [可选] LLM 调用失败（限流/超时/服务端错误）的重试次数，0=不重试（默认 3）。
# LLM_NUM_RETRIES=3

# [可选] 连续多少次相同工具调用就判定卡住、提前收尾，0=关闭（默认 3）。仅 custom 后端。
# STUCK_REPEAT_THRESHOLD=3

# [可选] 只保留最近 N 次工具输出的完整内容，更早的遮蔽成一行摘要，0=不遮蔽（默认 6）。仅 custom 后端。
# OBS_KEEP_FULL=6

# [可选] read_file 单次返回的最大字节数，防撑爆上下文（默认 20000）。
# MAX_READ_BYTES=20000

# [可选] grep_code 单次返回的最大匹配条数（默认 100）。
# MAX_GREP_MATCHES=100

# [可选] list_dir 单次返回的最大条目数（默认 300）。
# MAX_LIST_ENTRIES=300

# ----------------------------------------------------------------------------
# 离线索引（方案 2，scripts/index.sh 构建）
# ----------------------------------------------------------------------------

# [可选] 索引 SQLite 文件路径（默认 ./index/code_index.db）。
# INDEX_DB_PATH=./index/code_index.db

# [可选] 是否用索引加速 find_symbol/grep_code，0=强制 live scan（默认 1）。
# USE_INDEX=1

# [可选] 精确"X 定义在哪"问题直接查索引返回、跳过 LLM，0=关（默认 1）。
# USE_SHORTCUT=1

# ----------------------------------------------------------------------------
# 知识飞轮（方案 3）—— 问答后沉淀、下次召回作线索
# ----------------------------------------------------------------------------

# [可选] 知识库 SQLite 路径（默认 ./index/knowledge.db）。
# KNOWLEDGE_DB_PATH=./index/knowledge.db

# [可选] 是否启用知识沉淀飞轮（默认 0=关，验证召回命中率后再开）。
# USE_KNOWLEDGE=1

# [可选] 是否把 docs/code-knowledge/<repo>/ 的稳定知识地图注入 prompt（默认 1=开）。
# CODE_KNOWLEDGE_MAP_ENABLED=1

# [可选] 知识地图最多注入多少张卡片摘要（默认 12）。
# CODE_KNOWLEDGE_MAP_MAX_CARDS=12

# [可选] 是否把结构化 Assert 排障知识注入 prompt（默认 1=开）。
# ASSERT_KNOWLEDGE_ENABLED=1

# [可选] 每次最多注入多少个 Assert 排障条目（默认 4）。
# ASSERT_KNOWLEDGE_MAX_ITEMS=4
