# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Scripts in scripts/ auto-load .env; for raw `python main.py` either export
# these yourself or `set -a; source .env; set +a` first.

# Required: auth token for the mushigen proxy.
LLM_API_KEY=sk-your-token-here

# Target codebase to analyze (game server / combat / client / engine).
# Defaults to ./target_code (sample code) if unset.
TARGET_CODE_PATH=/path/to/game-code

# Agent backend: "custom" (litellm loop, default) or "sdk" (Claude Agent SDK).
# AGENT_BACKEND=custom

# --- custom backend (litellm via mushigen proxy) ---
# LLM_MODEL=vertex_ai/gemini-3.5-flash
# LLM_API_BASE=https://mushigen.comet.scopelyai.com/v1

# --- sdk backend (Claude Agent SDK + Claude Code CLI, routed to Bedrock) ---
# Requires these too (the CLI reads them); SDK_MODEL defaults to ANTHROPIC_MODEL.
# SDK_MODEL=us.anthropic.claude-opus-4-8
# CLAUDE_CODE_USE_BEDROCK=1
# ANTHROPIC_BEDROCK_BASE_URL=https://mushigen.comet.scopelyai.com/bedrock
# CLAUDE_CODE_SKIP_BEDROCK_AUTH=1
# AWS_REGION=us-east-1
# ANTHROPIC_AUTH_TOKEN=sk-your-token-here

# Optional overrides (defaults shown in config.py):
# SERVICE_PORT=8900
# AGENT_MAX_ITERATIONS=12
